@page "/analytics"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Recipe_Nutrition_App.Services

@inject RecipeService RecipeService

<PageTitle>Analytics</PageTitle>

<div class="container-fluid py-4 px-3 px-md-4">

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-graph-up-arrow me-2 text-success"></i>Analytics
            </h2>
        </div>
        <button class="btn btn-outline-success btn-sm" @onclick="ExecuteSearch">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                <!--  Text search — @bind:event="oninput" fires on every keystroke -->
                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold small">
                        <i class="bi bi-search me-1"></i>Search (name or ingredient)
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text"
                               @bind="SearchText"
                               @bind:event="oninput"
                               class="form-control"
                               placeholder="Search by recipe name or ingredient..." />
                    </div>
                </div>

                <div class="col-6 col-md-4">
                    <label class="form-label fw-semibold small">
                        <i class="bi bi-tag me-1"></i>Category
                    </label>
                    <select class="form-select" @bind="SelectedCategory" @bind:event="onchange"
                            @bind:after="ExecuteSearch">
                        <option value="">All Categories</option>
                        @foreach (var cat in AllCategories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>

                <div class="col-6 col-md-4">
                    <label class="form-label fw-semibold small">
                        <i class="bi bi-globe2 me-1"></i>Cuisine
                    </label>
                    <select class="form-select" @bind="SelectedCuisine" @bind:event="onchange"
                            @bind:after="ExecuteSearch">
                        <option value="">All Cuisines</option>
                        @foreach (var c in AllCuisines)
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Active filter badges -->
            @if (!string.IsNullOrEmpty(SearchText) || !string.IsNullOrEmpty(SelectedCategory) || !string.IsNullOrEmpty(SelectedCuisine))
            {
                <div class="mt-3 d-flex flex-wrap gap-2 align-items-center">
                    <small class="text-muted">Active filters:</small>
                    @if (!string.IsNullOrEmpty(SearchText))
                    {
                        <span class="badge bg-dark">
                            <i class="bi bi-search me-1"></i>@SearchText
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(SelectedCategory))
                    {
                        <span class="badge bg-success">@SelectedCategory</span>
                    }
                    @if (!string.IsNullOrEmpty(SelectedCuisine))
                    {
                        <span class="badge bg-primary">@SelectedCuisine</span>
                    }
                    <button class="btn btn-link btn-sm p-0 text-muted" @onclick="ClearAllFilters">
                        Clear all
                    </button>
                </div>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Result count -->
        <p class="text-muted small mb-3">
            Showing <strong class="text-success">@FilteredRecipes.Count</strong> recipes
            @if (!string.IsNullOrEmpty(SearchText) || !string.IsNullOrEmpty(SelectedCategory) || !string.IsNullOrEmpty(SelectedCuisine))
            {
                <span>(filtered by server-side IQueryable — TP10)</span>
            }
        </p>

        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <KpiCard Title="Recipes Found"
                         Value="@FilteredRecipes.Count.ToString()"
                         BackgroundColorClass="bg-success"
                         IconClass="bi-funnel-fill" />
            </div>
            <div class="col-6 col-md-3">
                <KpiCard Title="Avg Total kcal"
                         Value="@($"{FilteredAvgTotal:F0} kcal")"
                         BackgroundColorClass="bg-warning"
                         IconClass="bi-fire" />
            </div>
            <div class="col-6 col-md-3">
                <KpiCard Title="Avg kcal/Serving"
                         Value="@($"{FilteredAvgServing:F0} kcal")"
                         BackgroundColorClass="bg-primary"
                         IconClass="bi-person-fill" />
            </div>
            <div class="col-6 col-md-3">
                <KpiCard Title="Highest kcal"
                         Value="@($"{FilteredMax:F0} kcal")"
                         BackgroundColorClass="bg-danger"
                         IconClass="bi-trophy-fill" />
            </div>
        </div>

        <div class="row g-4 mb-4">

            <!-- Donut: filtered category distribution -->
            <div class="col-md-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">
                            <i class="bi bi-pie-chart-fill text-success me-2"></i>Category Breakdown
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (FilteredCategoryStats.Any())
                        {
                            <RadzenChart>
                                <RadzenDonutSeries Data="@FilteredCategoryStats"
                                                  CategoryProperty="CategoryName"
                                                  ValueProperty="Count" />
                            </RadzenChart>
                        }
                        else
                        {
                            <p class="text-muted text-center py-4">No data</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Column: filtered cuisine distribution -->
            <div class="col-md-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">
                            <i class="bi bi-bar-chart text-primary me-2"></i>Cuisine Distribution
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (FilteredCuisineStats.Any())
                        {
                            <RadzenChart>
                                <RadzenColumnSeries Data="@FilteredCuisineStats"
                                                   CategoryProperty="Cuisine"
                                                   ValueProperty="RecipeCount"
                                                   Title="Recipes"
                                                   Fill="#3498db" />
                                <RadzenLegend Visible="false" />
                            </RadzenChart>
                        }
                        else
                        {
                            <p class="text-muted text-center py-4">No data</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-table me-2 text-success"></i>Recipe Detail
                    <span class="badge bg-secondary ms-2">@FilteredRecipes.Count</span>
                </h5>
                <div class="d-flex gap-2 align-items-center">
                    <label class="small text-muted mb-0">Sort:</label>
                    <select class="form-select form-select-sm" style="width:auto"
                            @bind="SortMode" @bind:after="ApplySort">
                        <option value="name">Name A→Z</option>
                        <option value="cal_desc">kcal ↓</option>
                        <option value="cal_asc">kcal ↑</option>
                        <option value="serving_desc">kcal/Serving ↓</option>
                    </select>
                </div>
            </div>
            <div class="card-body p-0">
                <RecipeTable Recipes="SortedRecipes" ShowActions="false" />
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;

    private List<Recipe> FilteredRecipes = new();
    private List<string> AllCategories   = new();
    private List<string> AllCuisines     = new();

    private string _searchText = "";
    private string SelectedCategory = "";
    private string SelectedCuisine  = "";
    private string SortMode         = "name";

    private string SearchText
    {
        get => _searchText;
        set
        {
            _searchText = value;
            _ = ExecuteSearch();   
        }
    }

    private double FilteredAvgTotal   => FilteredRecipes.Any() ? FilteredRecipes.Average(r => RecipeService.CalculateTotalCalories(r)) : 0;
    private double FilteredAvgServing => FilteredRecipes.Any() ? FilteredRecipes.Average(r => RecipeService.CalculateCaloriesPerServing(r)) : 0;
    private double FilteredMax        => FilteredRecipes.Any() ? FilteredRecipes.Max(r => RecipeService.CalculateTotalCalories(r)) : 0;

    private List<CategoryStat> FilteredCategoryStats =>
        FilteredRecipes
            .GroupBy(r => r.Category ?? "Unknown")
            .Select(g => new CategoryStat { CategoryName = g.Key, Count = g.Count() })
            .OrderByDescending(x => x.Count)
            .ToList();

    private List<CuisineStats> FilteredCuisineStats =>
        FilteredRecipes
            .GroupBy(r => r.Cuisine ?? "Unknown")
            .Select(g => new CuisineStats
            {
                Cuisine         = g.Key,
                RecipeCount     = g.Count(),
                AverageCalories = Math.Round(g.Average(r => RecipeService.CalculateTotalCalories(r)), 1)
            })
            .OrderByDescending(x => x.RecipeCount)
            .ToList();

    private List<Recipe> SortedRecipes => SortMode switch
    {
        "cal_desc"     => FilteredRecipes.OrderByDescending(r => RecipeService.CalculateTotalCalories(r)).ToList(),
        "cal_asc"      => FilteredRecipes.OrderBy(r => RecipeService.CalculateTotalCalories(r)).ToList(),
        "serving_desc" => FilteredRecipes.OrderByDescending(r => RecipeService.CalculateCaloriesPerServing(r)).ToList(),
        _              => FilteredRecipes.OrderBy(r => r.Name).ToList()
    };

    protected override async Task OnInitializedAsync()
    {
        
        var all = await RecipeService.GetAllRecipesAsync();
        AllCategories = all.Select(r => r.Category).Where(c => !string.IsNullOrEmpty(c))
                           .Distinct().OrderBy(x => x).ToList()!;
        AllCuisines   = all.Select(r => r.Cuisine).Where(c => !string.IsNullOrEmpty(c))
                           .Distinct().OrderBy(x => x).ToList()!;

        await ExecuteSearch();
        isLoading = false;
    }

    private async Task ExecuteSearch()
    {
        FilteredRecipes = await RecipeService.SearchRecipesAsync(
            searchTerm: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
            category:   string.IsNullOrEmpty(SelectedCategory) ? null : SelectedCategory,
            cuisine:    string.IsNullOrEmpty(SelectedCuisine)  ? null : SelectedCuisine
        );
    }

    private void ApplySort()
    {
       
        StateHasChanged();
    }

    private async Task ClearAllFilters()
    {
        _searchText      = "";
        SelectedCategory = "";
        SelectedCuisine  = "";
        await ExecuteSearch();
    }
}
