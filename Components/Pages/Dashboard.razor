@page "/dashboard"
@using Microsoft.EntityFrameworkCore
@inject Recipe_Nutrition_App.Data.AppDbContext Db

<div class="app-container py-4">
    <h2 class="fw-bold mb-3"><i class="bi bi-graph-up me-2"></i>Dashboard</h2>

    <div class="summary-tiles mb-4">
        <div class="tile">
            <div class="fw-medium">Total Ingredients</div>
            <div class="muted">@TotalIngredients</div>
        </div>

        <div class="tile">
            <div class="fw-medium">Total Recipes</div>
            <div class="muted">@TotalRecipes</div>
        </div>

        <div class="tile">
            <div class="fw-medium">Avg Calories / Serving</div>
            <div class="muted">@AvgCaloriesPerServingDisplay</div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Recipes Breakdown by Category</h5>
            @if (CategoryCounts.Any())
            {
                <div class="mt-2">
                    @foreach (var kv in CategoryCounts)
                    {
                        <div class="d-flex justify-content-between py-1">
                            <div>@kv.Key</div>
                            <div class="muted">@kv.Value</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="muted">No recipes available yet.</div>
            }
        </div>
    </div>
</div>

@code {
    private int TotalIngredients;
    private int TotalRecipes;
    private double AvgCaloriesPerServing;
    private string AvgCaloriesPerServingDisplay => double.IsNaN(AvgCaloriesPerServing) ? "—" : Math.Round(AvgCaloriesPerServing,1) + " kcal";
    private Dictionary<string,int> CategoryCounts = new();

    protected override async Task OnInitializedAsync()
    {
        TotalIngredients = await Db.Ingredients.CountAsync();
        TotalRecipes = await Db.Recipes.CountAsync();

        // compute calories per recipe by summing Quantity * Ingredient.Calories
        var recipes = await Db.Recipes
            .Include(r => r.RecipeIngredients)
                .ThenInclude(ri => ri.Ingredient)
            .ToListAsync();

        var perServingList = new List<double>();

        foreach (var r in recipes)
        {
            double total = 0;
            foreach (var ri in r.RecipeIngredients)
            {
                if (ri.Ingredient != null)
                {
                    total += ri.Quantity * ri.Ingredient.Calories;
                }
            }
            if (r.Servings > 0)
                perServingList.Add(total / r.Servings);
        }

        AvgCaloriesPerServing = perServingList.Any() ? perServingList.Average() : double.NaN;

        // category counts
        CategoryCounts = await Db.Recipes
            .GroupBy(r => r.Category)
            .Select(g => new { Category = g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.Category ?? "Unspecified", x => x.Count);
    }
}
