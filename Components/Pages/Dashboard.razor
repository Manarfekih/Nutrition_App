@page "/dashboard"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Recipe_Nutrition_App.Data
@using Recipe_Nutrition_App.Services

@inject RecipeService RecipeService
@inject AppDbContext Db

<PageTitle>Dashboard</PageTitle>

<div class="container-fluid py-4 px-3 px-md-4">

    <div class="mb-4">
        <h2 class="fw-bold mb-1">
            <i class="bi bi-speedometer2 me-2 text-success"></i>Dashboard
        </h2>
        <p class="text-muted">Analytical overview of your recipe collection</p>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row mb-4 g-3">
            <div class="col-6 col-md-3">
                <KpiCard Title="Total Recipes"
                         Value="@TotalRecipes.ToString()"
                         BackgroundColorClass="bg-success"
                         IconClass="bi-book-fill" />
            </div>
            <div class="col-6 col-md-3">
                <KpiCard Title="Total Ingredients"
                         Value="@TotalIngredients.ToString()"
                         BackgroundColorClass="bg-primary"
                         IconClass="bi-basket-fill" />
            </div>
            <div class="col-6 col-md-3">
                <KpiCard Title="Avg kcal / Serving"
                         Value="@($"{AvgCalPerServing:F0} kcal")"
                         BackgroundColorClass="bg-warning"
                         IconClass="bi-fire" />
            </div>
            <div class="col-6 col-md-3">
                <KpiCard Title="Cuisines Covered"
                         Value="@CuisineStats.Count.ToString()"
                         BackgroundColorClass="bg-danger"
                         IconClass="bi-globe2" />
            </div>
        </div>

        <div class="row mb-4 g-4">

            <div class="col-md-8">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">
                            <i class="bi bi-bar-chart-fill text-success me-2"></i>
                            Recipes by Category
                            @if (SelectedCategory != null)
                            {
                                <span class="badge bg-success ms-2">@SelectedCategory</span>
                                <button class="btn btn-sm btn-link text-muted p-0 ms-2"
                                        @onclick="ClearCategoryFilter">
                                    <i class="bi bi-x-circle"></i> Clear filter
                                </button>
                            }
                        </h5>
                        <small class="text-muted">Click a bar to filter the recipe table </small>
                    </div>
                    <div class="card-body">
                        <RadzenChart SeriesClick="@OnCategoryBarClick">
                            <RadzenColumnSeries Data="@CategoryStats"
                                               CategoryProperty="CategoryName"
                                               ValueProperty="Count"
                                               Title="Recipes"
                                               Fill="#27ae60" />
                            <RadzenValueAxis>
                                <RadzenGridLines Visible="true" />
                            </RadzenValueAxis>
                            <RadzenLegend Visible="false" />
                        </RadzenChart>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">
                            <i class="bi bi-speedometer2 text-danger me-2"></i>Max Recipe Calories
                        </h5>
                    </div>
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <RadzenRadialGauge Style="width:100%; height:240px;">
                            <RadzenRadialGaugeScale Min="0" Max="@GaugeMax" Step="@GaugeStep">
                                <RadzenRadialGaugeScalePointer Value="@MaxCalories"
                                                               Length="0.6"
                                                               ShowValue="true" />
                                <RadzenRadialGaugeScaleRange From="0"         To="@(GaugeMax*0.35)" Fill="green" />
                                <RadzenRadialGaugeScaleRange From="@(GaugeMax*0.35)" To="@(GaugeMax*0.7)"  Fill="orange" />
                                <RadzenRadialGaugeScaleRange From="@(GaugeMax*0.7)"  To="@GaugeMax"        Fill="red" />
                            </RadzenRadialGaugeScale>
                        </RadzenRadialGauge>
                        <p class="text-muted small mt-2">kcal — highest recipe total</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== CHARTS ROW 2 ===== -->
        <div class="row mb-4 g-4">

            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">
                            <i class="bi bi-pie-chart-fill text-primary me-2"></i>Recipes by Cuisine
                        </h5>
                    </div>
                    <div class="card-body">
                        <!-- TP9: RadzenDonutSeries -->
                        <RadzenChart>
                            <RadzenDonutSeries Data="@CuisineStats"
                                              CategoryProperty="Cuisine"
                                              ValueProperty="RecipeCount"
                                              Title="Cuisine">
                                <TitleTemplate>
                                    <div class="rz-donut-content">
                                        <div style="font-size:.75rem;color:#666">Total</div>
                                        <div style="font-size:1.5rem;font-weight:700">@TotalRecipes</div>
                                    </div>
                                </TitleTemplate>
                            </RadzenDonutSeries>
                        </RadzenChart>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">
                            <i class="bi bi-graph-up text-warning me-2"></i>Avg Calories by Cuisine
                        </h5>
                    </div>
                    <div class="card-body">
                        <RadzenChart>
                            <RadzenColumnSeries Data="@CuisineStats"
                                               CategoryProperty="Cuisine"
                                               ValueProperty="AverageCalories"
                                               Title="Avg kcal"
                                               Fill="#f39c12" />
                            <RadzenValueAxis Formatter="@((v) => $"{Math.Round((double)v, 0)} kcal")" />
                            <RadzenLegend Visible="false" />
                        </RadzenChart>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-table me-2 text-success"></i>
                    @(SelectedCategory != null ? $"Recipes — {SelectedCategory}" : "All Recipes")
                    <span class="badge bg-secondary ms-2">@FilteredRecipes.Count</span>
                </h5>
            </div>
            <div class="card-body p-0">
                <RecipeTable Recipes="FilteredRecipes" ShowActions="false" />
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;

    private int    TotalRecipes;
    private int    TotalIngredients;
    private double AvgCalPerServing;
    private double MaxCalories;
    private double GaugeMax  => Math.Max(1000, Math.Ceiling(MaxCalories / 500) * 500);
    private double GaugeStep => GaugeMax / 5;

    private List<CategoryStat> CategoryStats = new();
    private List<CuisineStats> CuisineStats  = new();

    private string?       SelectedCategory = null;
    private List<Recipe>  AllRecipes       = new();
    private List<Recipe>  FilteredRecipes  = new();

    protected override async Task OnInitializedAsync()
    {
        TotalIngredients = await Db.Ingredients.CountAsync();
        TotalRecipes     = await Db.Recipes.CountAsync();

        CategoryStats = await RecipeService.GetCategoryStatsAsync();
        CuisineStats  = await RecipeService.GetStatsByCuisineAsync();

        AllRecipes = await RecipeService.GetAllRecipesAsync();

        if (AllRecipes.Any())
        {
            MaxCalories = AllRecipes.Max(r => RecipeService.CalculateTotalCalories(r));
            var servingCals = AllRecipes
                .Where(r => r.Servings > 0)
                .Select(r => RecipeService.CalculateCaloriesPerServing(r));
            AvgCalPerServing = servingCals.Any() ? servingCals.Average() : 0;
        }

        FilteredRecipes = AllRecipes;
        isLoading = false;
    }

    private void OnCategoryBarClick(SeriesClickEventArgs args)
    {
        var clicked = args.Category?.ToString();

        if (SelectedCategory == clicked)
            SelectedCategory = null;
        else
            SelectedCategory = clicked;

        FilteredRecipes = SelectedCategory == null
            ? AllRecipes
            : AllRecipes.Where(r => r.Category == SelectedCategory).ToList();
    }

    private void ClearCategoryFilter()
    {
        SelectedCategory = null;
        FilteredRecipes  = AllRecipes;
    }
}
