@rendermode InteractiveServer

<nav class="navbar navbar-expand-lg navbar-custom shadow-sm px-3 px-lg-4">
    <div class="container-fluid p-0">
        
        <!-- Logo / Brand -->
         <a class="navbar-brand" href="/">
            <div class="brand-logo-wrapper">
                <img src="images/app_logo.png" 
                     alt="Recipe Nutrition" 
                     class="brand-logo-round">
            </div>
            <div class="brand-text-wrapper">
                <span class="brand-text">هَيَّا بِسْمِ اللَّه</span>
                <span class="brand-tagline">Nutrition Tracker</span>
            </div>
        </a>

        <!-- Toggler Button -->
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Collapsible Content -->
        <div class="collapse navbar-collapse" id="mainNavbar">
            
            <!-- Main Navigation -->
            <ul class="navbar-nav mx-auto gap-1 gap-lg-2 my-3 my-lg-0">
                <li class="nav-item">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door nav-icon"></i>
                        <span>Home</span>
                    </NavLink>
                </li>
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/ingredients">
                                <i class="bi bi-basket nav-icon"></i>
                                <span>Ingredients</span>
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/recipes">
                                <i class="bi bi-book nav-icon"></i>
                                <span>Recipes</span>
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/dashboard">
                                <i class="bi bi-bar-chart-steps nav-icon"></i>
                                <span>Dashboard</span>
                            </NavLink>
                        </li>
                    </Authorized>
                </AuthorizeView>
            </ul>

            <!-- Right Section -->
            <div class="d-flex align-items-center gap-2 my-3 my-lg-0 ms-lg-auto">
                <AuthorizeView>
                    <Authorized>
                        <span class="text-muted small d-none d-md-inline">@context.User.Identity?.Name</span>
                        <a class="btn btn-outline-secondary btn-sm" href="/Account/Logout">Sign out</a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="btn btn-outline-primary btn-sm" href="/Account/Login">Sign in</a>
                        <a class="btn btn-primary btn-sm" href="/Account/Register">Register</a>
                    </NotAuthorized>
                </AuthorizeView>

                <div class="chef-section d-flex align-items-center gap-3 border-start ps-3 ms-1">
                    <div class="chef-card">
                        <div class="chef-avatar-wrapper">
                            <i class="bi bi-person-check-fill"></i>
                        </div>
                        <div class="chef-details d-none d-md-block">
                            <div class="chef-title">Chef's Corner</div>
                            <div class="chef-subtitle">Healthy Recipes</div>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</nav>
