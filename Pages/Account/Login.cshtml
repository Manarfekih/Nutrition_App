@page
@model Recipe_Nutrition_App.Pages.Account.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/app.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
</head>
<body class="auth-shell">
    <div class="auth-card">
        <div class="auth-card-header">
            <a class="auth-brand" href="/">
                <img class="auth-brand-logo" src="~/images/app_logo.png" alt="Recipe Nutrition" />
                <div>
                    <p class="auth-brand-title mb-0">Nutrition Tracker</p>
                    <p class="auth-brand-subtitle mb-0">Sign in to continue</p>
                </div>
            </a>
        </div>

        <div class="auth-card-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger mb-3" role="alert">@Model.ErrorMessage</div>
            }

            <form method="post">
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

                <div class="form-floating mb-3">
                    <input class="form-control" asp-for="Input.Email" autocomplete="username" placeholder="name@example.com" />
                    <label asp-for="Input.Email"></label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input class="form-control" asp-for="Input.Password" autocomplete="current-password" placeholder="Password" />
                    <label asp-for="Input.Password"></label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe"></label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Sign in
                </button>
            </form>

            <p class="auth-help">
                No account? <a href="/Account/Register">Create one</a>
            </p>
            <p class="mt-3 mb-0 text-center">
                <a class="auth-footer-link" href="/">
                    <i class="bi bi-arrow-left"></i> Back to home
                </a>
            </p>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
</body>
</html>
